{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and balance info",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "nome": { "type": "string" },
        "email": { "type": "string" },
        "saldo": { "type": "number" },
        "pixKey": { "type": "string" },
        "role": { "type": "string" },
        "btcBalance": { "type": "number" },
        "ethBalance": { "type": "number" },
        "solBalance": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "nome", "email", "saldo", "pixKey"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A financial transaction between users or systems",
      "type": "object",
      "properties": {
        "senderUid": { "type": "string" },
        "senderName": { "type": "string" },
        "recipientUid": { "type": "string" },
        "recipientName": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string" },
        "action": { "type": "string" },
        "cryptoAmount": { "type": "number" },
        "cryptoSymbol": { "type": "string" },
        "paymentSource": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["amount", "timestamp"]
    },
    "Card": {
      "title": "Card",
      "description": "Virtual card information",
      "type": "object",
      "properties": {
        "cardNumber": { "type": "string" },
        "cardHolder": { "type": "string" },
        "expiryDate": { "type": "string" },
        "cvv": { "type": "string" },
        "status": { "type": "string" },
        "type": { "type": "string" }
      },
      "required": ["cardNumber", "cardHolder", "expiryDate", "cvv", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User collection"
    },
    "/users/{userId}/cards/{cardId}": {
      "schema": "Card",
      "description": "User's virtual cards"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Global transactions collection"
    }
  }
}
