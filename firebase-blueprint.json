{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a bank user with their balance and profile information.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "Unique identifier for the user (Firebase Auth UID)."
        },
        "nome": {
          "type": "string",
          "description": "Full name of the user."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email address of the user."
        },
        "pixKey": {
          "type": "string",
          "description": "Custom PIX key of the user."
        },
        "saldo": {
          "type": "number",
          "description": "Current balance of the user in BRL."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the user account was created."
        }
      },
      "required": ["uid", "nome", "email", "saldo", "createdAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Represents a PIX transfer between users.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the transaction."
        },
        "senderUid": {
          "type": "string",
          "description": "UID of the user who sent the PIX."
        },
        "senderName": {
          "type": "string",
          "description": "Name of the sender."
        },
        "recipientUid": {
          "type": "string",
          "description": "UID of the user who received the PIX."
        },
        "recipientName": {
          "type": "string",
          "description": "Name of the recipient."
        },
        "amount": {
          "type": "number",
          "description": "Amount transferred."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the transaction occurred."
        }
      },
      "required": ["senderUid", "senderName", "recipientUid", "recipientName", "amount", "timestamp"]
    },
    "Card": {
      "title": "Card",
      "description": "Represents a virtual or physical bank card.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "cardNumber": { "type": "string" },
        "expiry": { "type": "string" },
        "cvv": { "type": "string" },
        "holderName": { "type": "string" },
        "type": { "type": "string", "enum": ["virtual", "physical"] },
        "status": { "type": "string", "enum": ["active", "blocked"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["cardNumber", "expiry", "cvv", "holderName", "type", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "Collection of users indexed by their Auth UID."
    },
    "/users/{uid}/cards/{cardId}": {
      "schema": "Card",
      "description": "Subcollection of cards belonging to a specific user."
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Collection of all PIX transactions."
    }
  }
}
