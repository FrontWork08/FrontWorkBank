rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      // Admin pode ser o email específico OU quem tem role 'admin'
      return isAuthenticated() && (
        request.auth.token.email == "frontwork08@gmail.com" ||
        request.auth.token.email == "frontwork@newbank.com"
      );
    }

    match /users/{userId} {
      // Aberto para o simulador bancário
      allow read: if true;
      
      // Permitir criação para novos usuários
      allow create: if true;
      
      // Permitir updates (para PIX e Admin)
      allow update: if true;

      match /cards/{cardId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /transactions/{transactionId} {
      // Usuários podem ler transações onde são remetente ou destinatário
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.senderUid || 
        request.auth.uid == resource.data.recipientUid ||
        request.auth.uid == resource.data.senderId || 
        request.auth.uid == resource.data.recipientId ||
        request.auth.uid == resource.data.from ||
        request.auth.uid == resource.data.to ||
        isAdmin()
      );
      
      // Criar transação (PIX, Investimentos, Cassino)
      allow create: if isAuthenticated() && (
        request.resource.data.from == request.auth.uid ||
        request.resource.data.to == request.auth.uid ||
        request.resource.data.senderId == request.auth.uid ||
        request.resource.data.recipientId == request.auth.uid
      );
    }
  }
}